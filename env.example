# Cost Console environment variables
# Copy this file to .env.local for local development.

# Required: base URL of the running Identity-Service instance.
# Used by Cost Console to validate sessions and relay project-scoped auth for `cost-console`.
IDENTITY_URL=http://localhost:4000

# Reserved for the future PostgreSQL/Prisma persistence phase.
# Not consumed by the current application runtime yet.
# DATABASE_URL=postgresql://cost_console:cost_console@localhost:5432/cost_console
