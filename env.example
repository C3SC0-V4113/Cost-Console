# Cost Console environment variables
# Copy this file to .env.local for local development.

# Required: base URL of the running Identity-Service instance.
# Used by Cost Console to validate sessions and relay project-scoped auth for `cost-console`.
IDENTITY_URL=http://localhost:4000

# PostgreSQL persistence (Prisma).
#
# For the standard local setup you do NOT need to set DATABASE_URL: the app
# defaults to the Docker Compose `postgres` service on host port 5433 in
# development. Do not point it at 5432 — that is the Identity-Service Postgres.
#
# Only set these to override the default (e.g. Supabase). DATABASE_URL is the
# runtime/pooled connection; DIRECT_URL is the direct connection Prisma Migrate
# uses (on Supabase pooled 6543 vs direct 5432; locally they are the same).
# DATABASE_URL=postgresql://cost_console:cost_console@localhost:5433/cost_console
# DIRECT_URL=postgresql://cost_console:cost_console@localhost:5433/cost_console
