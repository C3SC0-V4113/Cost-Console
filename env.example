# Cost Console environment variables
# Copy this file to .env.local for local development.

# Required: base URL of the running Identity-Service instance.
# Used by Cost Console to validate sessions and relay project-scoped auth for `cost-console`.
IDENTITY_URL=http://localhost:4000

# PostgreSQL persistence (Prisma). Copy these into .env.local (or .env) for local
# development. The Docker Compose `postgres` service maps host port 5433 because
# Identity-Service already uses 5432 on the same machine.
#
# DATABASE_URL is the runtime/pooled connection used by the app and Prisma Client.
# DIRECT_URL is the direct connection Prisma Migrate uses. On Supabase these differ
# (pooled 6543 vs direct 5432); locally they are the same.
DATABASE_URL=postgresql://cost_console:cost_console@localhost:5433/cost_console
DIRECT_URL=postgresql://cost_console:cost_console@localhost:5433/cost_console
